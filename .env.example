# OpenSea API Key (Required for high rate limits or v2 endpoints access if restricted, otherwise get one from OpenSea Developer Portal)
OPENSEA_API_KEY=OPENSEA_API_KEY

# Discord Webhook URL where alerts will be posted
DISCORD_WEBHOOK=channel_webhook

# Comma-separated list of OpenSea collection slugs to track (e.g., boredapeyachtclub,mutant-ape-yacht-club)
COLLECTIONS=slug

# Interval in seconds between checks for new sales (default: 15)
CHECK_INTERVAL=15

# Path to the state JSON file (default: state.json)
STATE_FILE=state.json

# Starting point for first-run query (when there is no state history). Options:
# - today (Starts from today at 00:00:00 UTC)
# - yesterday (Starts from yesterday at 00:00:00 UTC)
# - now / latest (Starts from current time; alerts only for sales occurring after the bot starts)
# - Unix timestamp (e.g., 1715000000)
# - ISO 8601 string (e.g., 2026-07-04T12:00:00Z)
# - leave empty to just get the latest 20 events regardless of timestamp
START_TIME=timeperiod (today-yesterday)
